{
    "version": "2.6.14",
    "description": "A free Japanese text editor for Windows.",
    "homepage": "https://www.haijin-boys.com/wiki/",
    "license": "zlib",
    "architecture": {
        "64bit": {
            "url": "http://www.haijin-boys.com/download/MeryPortable-x64-2.6.14.zip",
            "hash": "3d165df5dddf2a2079b48406b8ea7f773fa8101dc34c8c9368032a97790641ba"
        }
    },
    "extract_dir": "Mery",
    "pre_install": [
        "$manifest.persist | ForEach-Object {",
        "    if (-not (Test-Path \"$persist_dir\\$_\")) { New-Item \"$dir\\$_\" -ItemType file | Out-Null }",
        "}"
    ],
    "bin": "Mery.exe",
    "shortcuts": [
        [
            "Mery.exe",
            "Mery"
        ]
    ],
    "persist": [
        "Mery.ini",
        "Mery.his"
    ],
    "checkver": {
        "url": "https://www.haijin-boys.com/software/mery",
        "re": "Ver ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "http://www.haijin-boys.com/download/MeryPortable-x64-$version.zip"
            }
        }
    }
}
